rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles (legacy/client-side)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Backend-managed profiles (stability_score, missions, etc.)
    match /user_profiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Friendships — both participants can read
    match /friendships/{docId} {
      allow read: if request.auth != null &&
        (resource.data.uid_a == request.auth.uid ||
         resource.data.uid_b == request.auth.uid);
      allow write: if false;
    }

    // Real-time chat — only participants can read/send
    match /chat_rooms/{roomId}/messages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.sender_uid == request.auth.uid;
      allow update, delete: if false;
    }

    // AI chat history — own messages only
    match /ai_chat_messages/{docId} {
      allow read: if request.auth != null &&
        resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
